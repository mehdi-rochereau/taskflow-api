# .env.example — template for environment configuration
# Copy this file to .env and fill in real values before running the application.
# This file IS committed to the repository — it contains no secrets.

# JWT
# Generate a secure random secret: openssl rand -hex 64
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long-change-this

# JWT expiration in milliseconds — 900000 = 15 minutes
JWT_EXPIRATION=900000

# true in production — cookies only transmitted over HTTPS
COOKIE_SECURE=true

# Refresh token validity in days
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Database
# "mysql" is the Docker Compose service name — containers reach each other by name.
# Change to your actual database host in production.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=taskflow
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password